# ---- NestJS API environment ----
# Neon Postgres connection string (use the POOLED connection string from Neon).
# Get it from: Neon dashboard -> your project -> Connection Details -> "Pooled connection".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Port the API listens on (frontend expects 3001 by default in development).
PORT=3001

# Comma-separated list of allowed browser origins (CORS).
# In production set this to your Vercel domain, e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# Public base URL of the FRONTEND. Used to build each guest's invite link
# (formUrl = `${PUBLIC_SITE_URL}/invite/${token}`).
PUBLIC_SITE_URL=http://localhost:3000
