# ---- Next.js frontend environment ----
# Base URL of the NestJS API.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public base URL of THIS site. Used to render each guest's invite link.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Optional) Override the event date/time used by the countdown (ISO 8601).
# Defaults to 2026-07-19 19:00 Sri Lanka time if unset.
NEXT_PUBLIC_EVENT_DATE=2026-07-19T19:00:00+05:30

# (Optional) Google Maps link for the venue "Open in Maps" button.
NEXT_PUBLIC_MAPS_URL=https://www.google.com/maps/search/?api=1&query=Shangri-La+Hotel+Colombo

# ---- Google Form RSVP pre-fill (optional) ----
# The "viewform" URL of your Google Form, e.g.
#   https://docs.google.com/forms/d/e/FORM_ID/viewform
NEXT_PUBLIC_GOOGLE_FORM_BASE_URL=
# The pre-fill field keys (look like "entry.123456789"). See README for how to find them.
NEXT_PUBLIC_GF_ENTRY_NAME=
NEXT_PUBLIC_GF_ENTRY_TOKEN=
NEXT_PUBLIC_GF_ENTRY_SCOPE=
